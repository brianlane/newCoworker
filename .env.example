# ──────────────────────────────────────────────────────────
# New Coworker — Environment Variables
# Copy this to .env and fill in real values before running.
# ──────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────
# All three MUST be from the SAME Supabase project.
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── VPS voice bridge (Gemini Live) ──────────────────────
# Used by `vps/voice-bridge` (also loads repo-root `.env`). Get a key from Google AI Studio.
GOOGLE_API_KEY=
# Optional; defaults to GOOGLE_API_KEY
# GEMINI_API_KEY=
# Live model id — Gemini API native-audio Live (see https://ai.google.dev/gemini-api/docs/live-guide )
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Session wall-clock cap (ms). Default 14 minutes — under typical Live API audio limits; tune per Google’s current docs.
GEMINI_LIVE_SESSION_MAX_MS=840000
# First spoken “wrap up soon” coordinator prompt this many ms before the cap.
GEMINI_LIVE_SESSION_WARN_BEFORE_MS=60000
# Second, firmer prompt this many ms before the cap.
GEMINI_LIVE_SESSION_FINAL_NUDGE_MS=15000
# Bridge-only: set false to accept Telnyx media but skip Gemini Live (rollout / degraded host).
# GEMINI_LIVE_ENABLED=true

# ── Stripe ───────────────────────────────────────────────
# Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# One-time voice bonus (a la carte): Checkout Session in payment mode with metadata:
#   checkoutKind=voice_bonus_seconds, businessId=<uuid>, voiceSeconds=<int>.
# Optional if the app later creates the one-time Checkout Session itself instead of using a
# Stripe Dashboard payment link / ad hoc Checkout in v1.
# STRIPE_VOICE_BONUS_PRICE_ID=price_...
# Requires an active Stripe subscription on the business; webhook computes expires_at = max(current_period_end, purchased_at + 30d) (UTC).
# Webhook calls apply_voice_bonus_grant_from_checkout (idempotent on session id); RPC also enforces DB subscription active + stripe_subscription_id.
# Stripe webhook endpoint must include:
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.paid
#   invoice.payment_failed
#   charge.refunded
#   charge.dispute.created
# Dashboard → Products → Price IDs for each tier/period combination
# Starter tier (24mo / 12mo / 1mo)
STRIPE_STARTER_24MO_PRICE_ID=price_...
STRIPE_STARTER_24MO_RENEWAL_PRICE_ID=price_...
STRIPE_STARTER_12MO_PRICE_ID=price_...
STRIPE_STARTER_12MO_RENEWAL_PRICE_ID=price_...
STRIPE_STARTER_1MO_PRICE_ID=price_...
STRIPE_STARTER_1MO_INTRO_COUPON_ID=coupon_...
# Standard tier (24mo / 12mo / 1mo)
STRIPE_STANDARD_24MO_PRICE_ID=price_...
STRIPE_STANDARD_24MO_RENEWAL_PRICE_ID=price_...
STRIPE_STANDARD_12MO_PRICE_ID=price_...
STRIPE_STANDARD_12MO_RENEWAL_PRICE_ID=price_...
STRIPE_STANDARD_1MO_PRICE_ID=price_...
STRIPE_STANDARD_1MO_INTRO_COUPON_ID=coupon_...

# ── Telnyx (voice + SMS) ─────────────────────────────────
# Mission Control → API Keys + Public Key (webhook verify)
TELNYX_API_KEY=KEY019A...
TELNYX_PUBLIC_KEY=base64_public_key_from_mission_control
TELNYX_MESSAGING_PROFILE_ID=40017c7e-...
# Optional E.164 when your messaging profile does not set a default from-number
TELNYX_SMS_FROM_E164=+15555550100
# Owner SMS for provisioning / urgent alerts (Rowboat + Edge notifications)
TELNYX_OWNER_PHONE=+15555550100
# HMAC secret shared by Edge (stream URL) and VPS voice bridge — openssl rand -hex 32
STREAM_URL_SIGNING_SECRET=
# Public WebSocket origin for the VPS media bridge, e.g. wss://voice.example.com
BRIDGE_MEDIA_WSS_ORIGIN=wss://your-bridge-host.example.com
# Edge `telnyx-voice-inbound`: false = answer + speak only (no AI stream URL). Rollout / kill-switch.
# VOICE_AI_STREAM_ENABLED=true
# Seconds since last bridge heartbeat before inbound calls route to the degraded path.
# Bridge posts a heartbeat every 30s; default 150 = ~5 missed beats (hysteresis, prevents flaps).
# BRIDGE_HEARTBEAT_TTL_SEC=150

# Edge Telnyx webhooks: per-IP rate limit (Postgres bucket). Defaults: 240 requests / 60s per route label.
# TELNYX_WEBHOOK_RATE_MAX_PER_MINUTE=240
# TELNYX_WEBHOOK_RATE_WINDOW_SEC=60
# When the rate-check RPC itself errors (e.g. DB blip), set this to `true` to allow the
# webhook through rather than returning 429. Default is fail-closed (`false`) so a broken
# DB cannot silently disable the rate limiter.
# TELNYX_WEBHOOK_RATE_FAIL_OPEN=false
# `telnyx-voice-failover`: default mode is maintenance answer+speak (§8). Optional scripted message:
# VOICE_FAILOVER_MAINTENANCE_MESSAGE=
# Optional: backup Telnyx Connection ID for `mode: transfer` JSON body (or default connection).
# TELNYX_FAILOVER_CONNECTION_ID=

# ── Hostinger ────────────────────────────────────────────
HOSTINGER_API_BASE_URL=https://developers.hostinger.com
HOSTINGER_API_TOKEN=your_hostinger_api_token

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_...
# Verified domain sender (from address — must match a Resend-verified domain)
MAILER_EMAIL=Your App <contact@yourdomain.com>
# Public contact / reply-to email (can be gmail)
CONTACT_EMAIL=yourteam@gmail.com

# ── Rowboat / VPS ────────────────────────────────────────
# Shared secret: Rowboat on the VPS calls POST /api/rowboat with Authorization: Bearer <this>.
# Must match ROWBOAT_GATEWAY_TOKEN in /opt/rowboat/.env on the VPS (see deploy-client.sh).
# Generate e.g.: openssl rand -hex 32
ROWBOAT_GATEWAY_TOKEN=generate_a_secure_random_token
ROWBOAT_GATEWAY_URL=https://agent.tunnel.newcoworker.com
# SMS worker (Edge) → Rowboat /chat on each VPS; Bearer must match the Rowboat API key on the VPS.
ROWBOAT_VPS_CHAT_BEARER=
# Optional: default Rowboat project UUID when business_configs.rowboat_project_id is null
ROWBOAT_DEFAULT_PROJECT_ID=
# Placeholders: {businessId}, {projectId}. Hostname must match how each business VPS is exposed
# (e.g. per-business tunnel DNS); the example assumes `{businessId}` is the UUID subdomain.
ROWBOAT_CHAT_URL_TEMPLATE=https://{businessId}.tunnel.newcoworker.com/api/v1/{projectId}/chat
# Bearer for sms-inbound-worker, voice-settlement-sweep, voice-low-balance-alerts, telnyx-voice-failover
# (schedule HTTP POST with Authorization: Bearer <INTERNAL_CRON_SECRET>).
# Required in production — use a dedicated secret, not the service role.
INTERNAL_CRON_SECRET=
# Local only: allow cron Bearer to match SUPABASE_SERVICE_ROLE_KEY when INTERNAL_CRON_SECRET is unset.
# CRON_ALLOW_SERVICE_ROLE_BEARER=true
# Token the Supabase Edge Function accepts for webhook auth
NOTIFICATIONS_WEBHOOK_TOKEN=generate_a_different_secure_token
# Provisioning progress (VPS → app): POST /api/provisioning/progress
# PROVISIONING_PROGRESS_TOKEN is optional; if unset, ROWBOAT_GATEWAY_TOKEN is used as Bearer token.
# PROVISIONING_PROGRESS_URL is set automatically by orchestrateProvisioning from NEXT_PUBLIC_APP_URL — do not set unless you override deploy wiring.
# PROVISIONING_PROGRESS_TOKEN=

# ── Cloudflare Tunnels (VPS) ─────────────────────────────
# Per-tenant mode (recommended): supply CLOUDFLARE_ACCOUNT_ID + a token scoped
# to "Cloudflare Tunnel: Edit" and "DNS: Edit" on the delegated zone. The
# orchestrator will create/reuse a tunnel named `nc-<businessId>` and derive a
# per-business install token automatically; CLOUDFLARE_TUNNEL_TOKEN is ignored
# whenever both of these are set (unless a call passes cloudflareTunnel: null).
CLOUDFLARE_ACCOUNT_ID=your_cf_account_id
CLOUDFLARE_API_TOKEN=your_cf_scoped_api_token
# The CF zone the public hostnames live in. Use the apex if the whole zone is
# on CF (e.g. "newcoworker.com"); use the delegated subdomain if only a slice
# is on CF (e.g. "tunnel.newcoworker.com").
CLOUDFLARE_TUNNEL_ZONE=tunnel.newcoworker.com
# Optional: override the suffix appended to businessId. Defaults to
# CLOUDFLARE_TUNNEL_ZONE. Set this when the zone is at the apex but you want
# hostnames at a deeper subdomain — e.g. zone="newcoworker.com" +
# suffix="tunnel.newcoworker.com" → "<businessId>.tunnel.newcoworker.com".
CLOUDFLARE_TUNNEL_HOSTNAME_SUFFIX=
CLOUDFLARE_TUNNEL_SERVICE_URL=http://localhost:3000
# Optional: pre-known zone id. When set the orchestrator skips the
# GET /zones?name=… lookup (saves a round-trip + lets the API token be
# scoped to a single zone's DNS without needing zone:list).
CLOUDFLARE_ZONE_ID=
# Legacy shared-tunnel fallback. Used only when CLOUDFLARE_API_TOKEN /
# CLOUDFLARE_ACCOUNT_ID are absent, or when the per-tenant provisioner fails.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ── Lightpanda (browser skills) ─────────────────────────
LIGHTPANDA_WSS_URL=wss://cdn.lightpanda.io/ws

# Encrypts stored integration secrets at rest (API keys, legacy tokens, etc.)
INTEGRATIONS_ENCRYPTION_KEY=replace_with_a_long_random_secret

# ── Workspace OAuth (Gmail, Calendar, Drive, Microsoft 365, etc.) ───────
# Backend integration secret (from your OAuth integration provider’s dashboard)
NANGO_SECRET_KEY=
# Optional API host override for the integration layer
# NANGO_HOST=https://api.nango.dev
# Public API host for the browser connect flow
# NEXT_PUBLIC_NANGO_API_HOST=https://api.nango.dev
# OAuth apps: use the redirect URL required by your integration provider (often documented as their hosted callback).
#
# Server: `src/lib/nango/workspace.ts` or POST /api/integrations/nango/proxy (session or ROWBOAT_GATEWAY_TOKEN)

# ── Microsoft / Azure (stub — direct app registration, if not using workspace OAuth above) ──
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Slack (stub) ─────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── KVM Docker integration tests (local) ─────────────────
# npm run test:integration — requires Docker; runs the correctness integration path against
# real Rowboat + Ollama stacks.
# Optional overrides:
# INTEGRATION_OLLAMA_MODEL_KVM2=llama3.2:3b
# INTEGRATION_OLLAMA_MODEL_KVM8=qwen3:4b-instruct
# Faster reruns: copy vps/integration/env.integration.example → .env.integration.local
# or run npm run test:integration:persist

# ── Admin ────────────────────────────────────────────────
# The email address that has admin access to /admin
ADMIN_EMAIL=admin@example.com
# The password used for direct admin sign-in (stored in Supabase Auth)
ADMIN_PASSWORD=your_secure_admin_password
