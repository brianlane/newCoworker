# ──────────────────────────────────────────────────────────
# New Coworker — Environment Variables
# Copy this to .env and fill in real values before running.
# ──────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────
# All three MUST be from the SAME Supabase project.
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Stripe ───────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard → Products → Price IDs for each tier
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_STANDARD_PRICE_ID=price_...

# ── Twilio ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_MESSAGING_SERVICE_SID=MG...
TWILIO_OWNER_PHONE=+15555550100

# ── ElevenLabs ───────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id

# ── Hostinger ────────────────────────────────────────────
HOSTINGER_API_BASE_URL=https://developers.hostinger.com
HOSTINGER_API_TOKEN=your_hostinger_api_token

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_...
# Verified domain sender (must match Resend domain)
CONTACT_EMAIL=support@example.com

# ── OpenClaw / VPS ───────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=generate_a_secure_random_token
OPENCLAW_GATEWAY_URL=https://agent.tunnel.newcoworker.com
# Token the Supabase Edge Function accepts for webhook auth
NOTIFICATIONS_WEBHOOK_TOKEN=generate_a_different_secure_token

# ── Cloudflare Tunnels (VPS) ─────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ── Lightpanda (browser skills) ─────────────────────────
LIGHTPANDA_WSS_URL=wss://cdn.lightpanda.io/ws

# ── Admin ────────────────────────────────────────────────
# The email address that has admin access to /admin
ADMIN_EMAIL=admin@example.com