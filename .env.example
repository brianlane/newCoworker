# ──────────────────────────────────────────────────────────
# New Coworker — Environment Variables
# Copy this to .env and fill in real values before running.
# ──────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public widget site key (ncw_pub_…) for OUR OWN marketing-site chat bubble
# (dogfooded website chat widget, backed by the internal pilot tenant).
# Public by design; unset = no bubble renders. See SiteChatWidget.tsx.
NEXT_PUBLIC_WEBCHAT_SITE_KEY=

# ── Supabase ─────────────────────────────────────────────
# All three MUST be from the SAME Supabase project.
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── VPS voice bridge (Gemini Live) ──────────────────────
# Used by `vps/voice-bridge` (also loads repo-root `.env`). Get a key from Google AI Studio.
GOOGLE_API_KEY=
# Optional; defaults to GOOGLE_API_KEY
# GEMINI_API_KEY=
# Live model id — Gemini API native-audio Live (see https://ai.google.dev/gemini-api/docs/live-guide )
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# Session wall-clock cap (ms). Default 14 minutes — under typical Live API audio limits; tune per Google’s current docs.
GEMINI_LIVE_SESSION_MAX_MS=840000
# First spoken “wrap up soon” coordinator prompt this many ms before the cap.
GEMINI_LIVE_SESSION_WARN_BEFORE_MS=60000
# Second, firmer prompt this many ms before the cap.
GEMINI_LIVE_SESSION_FINAL_NUDGE_MS=15000
# Bridge-only: set false to accept Telnyx media but skip Gemini Live (rollout / degraded host).
# GEMINI_LIVE_ENABLED=true
# Model served by Rowboat's `voice_task` agent via the VPS llm-router sidecar.
# The router forwards `gemini-*` requests to Google's OpenAI-compatible endpoint
# and everything else to Ollama. Defaults to gemini-3.1-flash in deploy-client.sh.
# GEMINI_ROWBOAT_MODEL=gemini-3.1-flash
# Model served by Rowboat's owner-dashboard `OwnerCoworker` agent via the same
# llm-router. Defaults to gemini-2.5-flash-lite in deploy-client.sh: the
# interactive owner surface sends a long prompt every turn and the CPU-only
# local model's cold prefill (~100s+) timed out, while Gemini answers in ~2.8s
# end-to-end for ~$0.0003/turn. Set to a local tag (e.g. qwen3:4b-instruct) to
# keep owner chat fully local. SMS's Coworker agent is unaffected (stays local).
# Injected into VPS deploys by provisioning + the fleet redeploy script (like
# GEMINI_ROWBOAT_MODEL), so setting it here/on Vercel reaches the seeded agent.
# Requires GOOGLE_API_KEY for gemini-* models — deploy-client.sh falls back to
# the local Ollama tag when a gemini-* model is set without a key.
# OWNER_CHAT_MODEL=gemini-2.5-flash-lite
# Per-business owner-chat (Gemini) spend cap per billing period, in micro-USD
# (1 USD = 1_000_000; default $10 = 10000000). Once a business crosses this for
# the period, the VPS chat-worker routes owner chat to the local Qwen agent
# (OwnerCoworkerLocal) until the next billing period. This var is read by the
# chat-worker (set it in /opt/chat-worker/.env on the VPS); leave unset to use
# the $10 default.
# OWNER_CHAT_SPEND_CAP_MICROS=10000000
# Optional Next.js/Vercel: model for `/api/onboard/website-ingest` (dashboard re-crawl).
# Takes precedence over GEMINI_ROWBOAT_MODEL. Legacy 1.x ids and gemini-3.1-* are coerced
# to a known-good `:generateContent` model when the API rejects or 404s the configured id.
# GEMINI_SUMMARY_MODEL=gemini-3-flash-preview
# Jina Reader (https://jina.ai/reader) API key for the website-ingest fallback:
# when the direct crawl finds no readable text (WAF challenge, or a JS-rendered
# SPA whose HTML is an empty shell), we fetch a browser-rendered markdown copy
# via r.jina.ai. Anonymous access is refused from cloud egress IPs ("bad
# network reputation"), so set this on Vercel or the fallback is effectively
# dead in production.
# JINA_API_KEY=
# Public origin of the Next.js app; the voice-bridge + Rowboat post to
# `${APP_BASE_URL}/api/voice/tools/*` with ROWBOAT_GATEWAY_TOKEN.
# Falls back to NEXT_PUBLIC_APP_URL inside orchestrate.ts.
# APP_BASE_URL=

# ── Stripe ───────────────────────────────────────────────
# Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# One-time voice bonus (a la carte): Checkout Session in payment mode with metadata:
#   checkoutKind=voice_bonus_seconds, businessId=<uuid>, voiceSeconds=<int>.
# Self-serve top-up lives at POST /api/billing/voice-bonus/checkout + the
# /dashboard/billing card. Three packs (30/120/600 min).
#
# Per-pack pricing precedence:
#   1. STRIPE_VOICE_BONUS_<N>MIN_CENTS (explicit cents override, wins when set).
#   2. VOICE_BONUS_USD_PER_MINUTE × minutes (flat-rate fallback).
#   3. Hard-coded $0.43/min default if neither is configured.
# Leaving any PRICE_ID unset disables that pack from the UI (the checkout route
# returns 400 if its pack ID is requested). Any change to a pack's effective
# price MUST be deployed together with a new PRICE_ID whose Stripe unit_amount
# matches — Stripe Prices are immutable, so rotate; don't try to update in place.
VOICE_BONUS_USD_PER_MINUTE=0.43
STRIPE_VOICE_BONUS_30MIN_PRICE_ID=price_...
STRIPE_VOICE_BONUS_30MIN_CENTS=1399
STRIPE_VOICE_BONUS_120MIN_PRICE_ID=price_...
STRIPE_VOICE_BONUS_120MIN_CENTS=5199
STRIPE_VOICE_BONUS_600MIN_PRICE_ID=price_...
STRIPE_VOICE_BONUS_600MIN_CENTS=25799
# Requires an active Stripe subscription on the business; webhook computes expires_at = max(current_period_end, purchased_at + 30d) (UTC).
# Webhook calls apply_voice_bonus_grant_from_checkout (idempotent on session id); RPC also enforces DB subscription active + stripe_subscription_id.
# Stripe webhook endpoint must include:
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.paid
#   invoice.payment_failed
#   charge.refunded
#   charge.dispute.created   # observational only (logged; never auto-voids)
#   charge.dispute.closed    # authoritative bonus-seconds clawback; only acts on status=lost
# Dispute semantics: the webhook handler deliberately does NOT void voice-bonus
# grants when a dispute is opened, because disputes can close as `won` or
# `warning_closed` (both leave funds with the merchant) and we have no re-grant
# path. Clawback fires exclusively on `charge.dispute.closed` + status=`lost`.
# Subscribing both events lets ops see open disputes in logs while preserving
# correctness for disputes the merchant successfully defends.
# Dashboard → Products → Price IDs for each tier/period combination
# 12/24-month PRICE_IDs are FULL-TERM prices (interval=month with
# interval_count=12|24, unit_amount = effective monthly × months) so the whole
# contract is collected at checkout — the tenant's Hostinger VPS is prepaid
# for the term. Create them with scripts/oneshot/create-term-prices.ts.
# RENEWAL_PRICE_IDs stay plain monthly: they drive the month-to-month rollover
# after the commitment via ensureCommitmentSchedule.
# Starter tier (24mo / 12mo / 1mo)
STRIPE_STARTER_24MO_PRICE_ID=price_...
STRIPE_STARTER_24MO_RENEWAL_PRICE_ID=price_...
STRIPE_STARTER_12MO_PRICE_ID=price_...
STRIPE_STARTER_12MO_RENEWAL_PRICE_ID=price_...
STRIPE_STARTER_1MO_PRICE_ID=price_...
STRIPE_STARTER_1MO_INTRO_COUPON_ID=coupon_...
# Standard tier (24mo / 12mo / 1mo)
STRIPE_STANDARD_24MO_PRICE_ID=price_...
STRIPE_STANDARD_24MO_RENEWAL_PRICE_ID=price_...
STRIPE_STANDARD_12MO_PRICE_ID=price_...
STRIPE_STANDARD_12MO_RENEWAL_PRICE_ID=price_...
STRIPE_STANDARD_1MO_PRICE_ID=price_...
STRIPE_STANDARD_1MO_INTRO_COUPON_ID=coupon_...
# White-glove onboarding (Phase C5): packages are priced in code
# (src/lib/plans/white-glove.ts, inline price_data — no Stripe product setup).
# Optional scheduling link shown in the confirmation email + billing page;
# unset → "reply to this email to schedule" fallback copy.
# WHITE_GLOVE_BOOKING_URL=https://cal.com/newcoworker/onboarding

# ── Telnyx (voice + SMS) ─────────────────────────────────
# Mission Control → API Keys + Public Key (webhook verify)
TELNYX_API_KEY=KEY019A...
TELNYX_PUBLIC_KEY=base64_public_key_from_mission_control
TELNYX_MESSAGING_PROFILE_ID=40017c7e-...
# Optional E.164 when your messaging profile does not set a default from-number
TELNYX_SMS_FROM_E164=+15555550100
# Owner SMS for provisioning / urgent alerts (Rowboat + Edge notifications)
TELNYX_OWNER_PHONE=+15555550100
# 10DLC (A2P SMS) registration: required for outbound SMS to US carriers.
# Without these, Verizon/AT&T/T-Mobile silently drop A2P traffic from your DIDs.
# - BRAND_ID: Telnyx's brand UUID after TCR/Telnyx brand registration completes.
# - CAMPAIGN_ID: Telnyx's campaign UUID once the shared campaign is ACTIVE.
# Until both are set, `attachBusinessDidToCampaign` records `pending` and
# the dashboard banner shows "Carrier registration in progress". The
# tendlc-attach-retry cron picks them up once populated.
TELNYX_10DLC_BRAND_ID=4b20019d-...
TELNYX_10DLC_CAMPAIGN_ID=
# HMAC secret shared by Edge (stream URL) and VPS voice bridge — openssl rand -hex 32
STREAM_URL_SIGNING_SECRET=
# Public WebSocket origin for the VPS media bridge, e.g. wss://voice.example.com
BRIDGE_MEDIA_WSS_ORIGIN=wss://your-bridge-host.example.com
# Edge `telnyx-voice-inbound`: false = answer + speak only (no AI stream URL). Rollout / kill-switch.
# VOICE_AI_STREAM_ENABLED=true
# Seconds since last bridge heartbeat before inbound calls route to the degraded path.
# Bridge posts a heartbeat every 30s; default 150 = ~5 missed beats (hysteresis, prevents flaps).
# BRIDGE_HEARTBEAT_TTL_SEC=150

# Edge Telnyx webhooks: per-IP rate limit (Postgres bucket). Defaults: 240 requests / 60s per route label.
# TELNYX_WEBHOOK_RATE_MAX_PER_MINUTE=240
# TELNYX_WEBHOOK_RATE_WINDOW_SEC=60
# When the rate-check RPC itself errors (e.g. DB blip), set this to `true` to allow the
# webhook through rather than returning 429. Default is fail-closed (`false`) so a broken
# DB cannot silently disable the rate limiter.
# TELNYX_WEBHOOK_RATE_FAIL_OPEN=false
# `telnyx-voice-failover`: default mode is maintenance answer+speak (§8). Optional scripted message:
# VOICE_FAILOVER_MAINTENANCE_MESSAGE=
# Optional: backup Telnyx Connection ID for `mode: transfer` JSON body (or default connection).
# TELNYX_FAILOVER_CONNECTION_ID=

# ── Meta (Facebook) Lead Ads — direct integration ────────
# Platform Meta app credentials (developers.facebook.com → New Coworker app
# → App settings → Basic). Powers the "Connect Facebook" card on
# /dashboard/integrations and the leadgen webhook at /api/webhooks/meta.
META_APP_ID=
META_APP_SECRET=
# Arbitrary shared secret echoed during Meta's webhook verification
# handshake (must match the value entered in the Meta app's Webhooks
# config). Generate: openssl rand -hex 24
META_WEBHOOK_VERIFY_TOKEN=
# Optional: model for the Messenger/Instagram DM reply engine
# (src/lib/messenger/engine.ts). Defaults to gemini-2.5-flash-lite.
# MESSENGER_GEMINI_ENGINE_MODEL=

# ── Secret encryption at rest (security review G5) ──────────────────
# 32-byte base64url master key for the AES-256-GCM envelope on stored
# secrets (vps_ssh_keys.private_key_pem, residency_backup_keys.passphrase).
# Generate: npx tsx debug/encrypt-secrets-backfill.ts --genkey
# MUST match between Vercel and this file (debug/redeploy tooling). After
# setting it, run debug/encrypt-secrets-backfill.ts --apply once.
# SECRETS_ENCRYPTION_KEY=

# ── Hostinger ────────────────────────────────────────────
HOSTINGER_API_BASE_URL=https://developers.hostinger.com
HOSTINGER_API_TOKEN=your_hostinger_api_token

# ── OVHcloud (Canada / Beauharnois provider path, enterprise) ─────────
# Purchases go through the OVHcloud US entity (our account) — its catalog
# sells the `-ca` plan codes with the Beauharnois (BHS) datacenter. Create
# all three credentials at once at https://api.us.ovhcloud.com/createToken/
# with rights GET/POST on /order/* and GET/POST/PUT on /vps/*. Only needed
# when provisioning `vps_provider='ovh'` tenants.
# OVH_API_BASE_URL=https://api.us.ovhcloud.com/1.0
# OVH_SUBSIDIARY=US
# OVH_APP_KEY=
# OVH_APP_SECRET=
# OVH_CONSUMER_KEY=
# Plan-code overrides when OVH renames catalog SKUs (audit with
# `npx tsx debug/ovh-catalog.ts`):
# OVH_PLAN_CODE_KVM1=
# OVH_PLAN_CODE_KVM2=
# OVH_PLAN_CODE_KVM4=
# OVH_PLAN_CODE_KVM8=

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=re_...
# Verified domain sender (from address — must match a Resend-verified domain)
MAILER_EMAIL=Your App <contact@yourdomain.com>
# Public contact / reply-to email (can be gmail)
CONTACT_EMAIL=yourteam@gmail.com

# ── Per-tenant AI mailboxes ──────────────────────────────
# Domain tenant AI mailboxes live under (default newcoworker.com). Must be a
# Resend-verified sending domain AND the domain whose inbound MX points at
# Cloudflare Email Routing. Used by the inbound webhook (address resolution)
# and the ai-flow-worker (outbound From). Defaults to newcoworker.com when unset.
TENANT_EMAIL_DOMAIN=newcoworker.com
# Shared bearer the Cloudflare Email Worker sends to POST /api/email/inbound.
# Set the SAME value as a `wrangler secret put EMAIL_INBOUND_SECRET` on the
# nc-email-inbound worker. Generate e.g.: openssl rand -hex 32
EMAIL_INBOUND_SECRET=generate_a_secure_random_token

# ── Rowboat / VPS ────────────────────────────────────────
# Shared secret: Rowboat on the VPS calls POST /api/rowboat with Authorization: Bearer <this>.
# Must match ROWBOAT_GATEWAY_TOKEN in /opt/rowboat/.env on the VPS (see deploy-client.sh).
# Generate e.g.: openssl rand -hex 32
ROWBOAT_GATEWAY_TOKEN=generate_a_secure_random_token
ROWBOAT_GATEWAY_URL=https://agent.newcoworker.com
# SMS worker (Edge) → Rowboat /chat on each VPS; Bearer must match the Rowboat API key on the VPS.
ROWBOAT_VPS_CHAT_BEARER=
# Optional: default Rowboat project UUID when business_configs.rowboat_project_id is null
ROWBOAT_DEFAULT_PROJECT_ID=
# Placeholders: {businessId}, {projectId}. Hostname must match how each business VPS is exposed
# (e.g. per-business tunnel DNS); the example assumes `{businessId}` is the UUID subdomain.
ROWBOAT_CHAT_URL_TEMPLATE=https://{businessId}.newcoworker.com/api/v1/{projectId}/chat
# Bearer for sms-inbound-worker, voice-settlement-sweep, voice-low-balance-alerts, telnyx-voice-failover,
# and the VPS chat-worker callback to /api/internal/dashboard-chat-summarize
# (schedule HTTP POST with Authorization: Bearer <INTERNAL_CRON_SECRET>).
# Required in production — use a dedicated secret, not the service role.
# VPS chat-worker uses this value as WORKER_VERCEL_BEARER in vps/chat-worker/.env.
INTERNAL_CRON_SECRET=
# Local only: allow cron Bearer to match SUPABASE_SERVICE_ROLE_KEY when INTERNAL_CRON_SECRET is unset.
# CRON_ALLOW_SERVICE_ROLE_BEARER=true
# Token the Supabase Edge Function accepts for webhook auth
NOTIFICATIONS_WEBHOOK_TOKEN=generate_a_different_secure_token
# Provisioning progress (VPS → app): POST /api/provisioning/progress
# PROVISIONING_PROGRESS_TOKEN is optional; if unset, ROWBOAT_GATEWAY_TOKEN is used as Bearer token.
# PROVISIONING_PROGRESS_URL is set automatically by orchestrateProvisioning from NEXT_PUBLIC_APP_URL — do not set unless you override deploy wiring.
# PROVISIONING_PROGRESS_TOKEN=

# ── Cloudflare Tunnels (VPS) ─────────────────────────────
# Per-tenant mode (recommended): supply CLOUDFLARE_ACCOUNT_ID + a token scoped
# to "Cloudflare Tunnel: Edit" and "DNS: Edit" on the delegated zone. The
# orchestrator will create/reuse a tunnel named `nc-<businessId>` and derive a
# per-business install token automatically; CLOUDFLARE_TUNNEL_TOKEN is ignored
# whenever both of these are set (unless a call passes cloudflareTunnel: null).
CLOUDFLARE_ACCOUNT_ID=your_cf_account_id
CLOUDFLARE_API_TOKEN=your_cf_scoped_api_token
# The CF zone the public hostnames live in. Set this to the APEX of the zone
# whose Universal SSL cert should cover tunnel hostnames — e.g.
# "newcoworker.com" produces "<businessId>.newcoworker.com" (one wildcard
# level), which Universal SSL covers for free. Going deeper than one level
# (e.g. "tunnel.newcoworker.com" → "<biz>.tunnel.newcoworker.com" → two
# levels) requires paid Total TLS / Advanced Certificate Manager because
# Universal SSL's wildcard only spans one level.
CLOUDFLARE_TUNNEL_ZONE=newcoworker.com
# Optional: override the suffix appended to businessId. Defaults to
# CLOUDFLARE_TUNNEL_ZONE. Only set this if you've upgraded the zone to a
# paid plan + enabled Total TLS and you genuinely want to nest hostnames
# deeper (e.g. for marketing namespacing).
CLOUDFLARE_TUNNEL_HOSTNAME_SUFFIX=
CLOUDFLARE_TUNNEL_SERVICE_URL=http://localhost:3000
# Voice bridge (Telnyx media WebSocket) gets its OWN public hostname on the
# same per-tenant tunnel — one cloudflared daemon, two ingress rules. Result:
# `wss://${CLOUDFLARE_TUNNEL_VOICE_HOSTNAME_PREFIX}<businessId>.<suffix>` with
# CF-issued TLS, no per-VPS Caddy/Let's Encrypt work. `BRIDGE_MEDIA_WSS_ORIGIN`
# below becomes a legacy escape hatch for shared-fleet deployments only —
# leave it blank when you want the per-tenant path to own the origin.
CLOUDFLARE_TUNNEL_VOICE_SERVICE_URL=http://127.0.0.1:8090
CLOUDFLARE_TUNNEL_VOICE_HOSTNAME_PREFIX=voice-
# AiFlow render service (headless Chromium for SPA / login-gated browse) gets
# its OWN per-tenant public hostname on the same tunnel, the same way the voice
# bridge does: `https://${CLOUDFLARE_TUNNEL_RENDER_HOSTNAME_PREFIX}<businessId>.<suffix>`
# → 127.0.0.1:8080. Only published on non-starter tiers (the render sidecar is
# never deployed on the memory-constrained starter/KVM2 box). Must agree with
# AIFLOW_RENDER_URL_TEMPLATE below.
CLOUDFLARE_TUNNEL_RENDER_SERVICE_URL=http://127.0.0.1:8080
CLOUDFLARE_TUNNEL_RENDER_HOSTNAME_PREFIX=render-
# Residency data API (enterprise data-residency opt-in) gets its OWN per-tenant
# public hostname on the same tunnel:
# `https://${CLOUDFLARE_TUNNEL_DATA_HOSTNAME_PREFIX}<businessId>.<suffix>`
# → 127.0.0.1:8091. Published ONLY for enterprise tenants whose
# businesses.data_residency_mode is past 'supabase' — everyone else gets no
# hostname and no backend (vps/data-api).
CLOUDFLARE_TUNNEL_DATA_SERVICE_URL=http://127.0.0.1:8091
CLOUDFLARE_TUNNEL_DATA_HOSTNAME_PREFIX=data-
# Optional: pre-known zone id. When set the orchestrator skips the
# GET /zones?name=… lookup (saves a round-trip + lets the API token be
# scoped to a single zone's DNS without needing zone:list).
CLOUDFLARE_ZONE_ID=
# Legacy shared-tunnel fallback. Used only when CLOUDFLARE_API_TOKEN /
# CLOUDFLARE_ACCOUNT_ID are absent, or when the per-tenant provisioner fails.
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ── AiFlow render service (Supabase Edge: ai-flow-worker secrets) ───────
# The render service is deployed PER-TENANT (one headless-Chromium sidecar on
# each business's VPS). The shared worker templates the businessId into the URL,
# exactly like ROWBOAT_CHAT_URL_TEMPLATE. Must agree with the Cloudflare render
# hostname prefix above. A static URL with no {businessId} placeholder is also
# accepted (single-host / local dev). Leave blank to fall back to static fetch
# (which cannot drive a login form — credentialed browse is then disabled).
AIFLOW_RENDER_URL_TEMPLATE=https://render-{businessId}.newcoworker.com/render
# Shared bearer the worker sends to every tenant's render sidecar (Authorization:
# Bearer). Set the SAME value as the render container's AIFLOW_RENDER_TOKEN
# (flowed to each VPS by the orchestrator). Always set in production.
AIFLOW_RENDER_TOKEN=replace_with_a_long_random_secret

# Encrypts stored integration secrets at rest (API keys, legacy tokens, etc.)
INTEGRATIONS_ENCRYPTION_KEY=replace_with_a_long_random_secret

# ── Workspace OAuth (Gmail, Calendar, Drive, Microsoft 365, etc.) ───────
# Backend integration secret (from your OAuth integration provider’s dashboard)
NANGO_SECRET_KEY=
# Optional API host override for the integration layer
# NANGO_HOST=https://api.nango.dev
# Public API host for the browser connect flow
# NEXT_PUBLIC_NANGO_API_HOST=https://api.nango.dev
# OAuth apps: use the redirect URL required by your integration provider (often documented as their hosted callback).
#
# Server: `src/lib/nango/workspace.ts` or POST /api/integrations/nango/proxy (session or ROWBOAT_GATEWAY_TOKEN)

# ── Microsoft / Azure (stub — direct app registration, if not using workspace OAuth above) ──
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Slack (stub) ─────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── KVM Docker integration tests (local) ─────────────────
# npm run test:integration — requires Docker; runs the correctness integration path against
# real Rowboat + Ollama stacks.
# Optional overrides:
# INTEGRATION_OLLAMA_MODEL_KVM2=llama3.2:3b
# INTEGRATION_OLLAMA_MODEL_KVM8=qwen3:4b-instruct
# Faster reruns: copy vps/integration/env.integration.example → .env.integration.local
# or run npm run test:integration:persist

# ── Admin ────────────────────────────────────────────────
# The email address that has admin access to /admin
ADMIN_EMAIL=admin@example.com
# The password used for direct admin sign-in (stored in Supabase Auth)
ADMIN_PASSWORD=your_secure_admin_password
