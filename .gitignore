# Private planning docs
PRDs/geminiChat.md

# Supabase CLI temp files (auto-generated by `supabase link`, contain infra secrets)
supabase/.temp/
# NOTE: supabase/config.toml is now TRACKED — it pins verify_jwt per edge
# function and CI's bulk `supabase functions deploy` must see those pins.
# It contains no secrets (project_id is public, it's in every Supabase URL);
# the link-time credentials live under supabase/.temp/, which stays ignored.

# Misc
*.tsbuildinfo
.testconvo
# Root-level one-off scratch scripts written by agent chats (e.g.
# .sandbox-testlead.local.mts, .backfill-permalink.local.mts) — local-only
# by convention, never committed.
.*.local.mts
test-results/
.vercel
debug/.bench-*.json
# Operational state written by debug/ scripts (teardown records, cost pulls,
# scratch probes) — local-only, may reference live infra.
debug/.kvm2-smoke.json
debug/.kvm1-smoke.json
debug/.migrate-vps-size-*.json
debug/.cost-data-*.json
debug/.tmp-*
vps/voice-bridge/dist/
deno.lock
supabase/functions/.env.itest
supabase/.branches
supabase/.temp
