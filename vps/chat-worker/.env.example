# Sample env for local development of the chat-worker. The production
# version is written by vps/scripts/deploy-client.sh into .env on each
# tenant's VPS — DO NOT commit a real .env to git.

# Supabase project (same across all tenants).
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-jwt>

# Rowboat reachable at this hostname inside the rowboat_default Docker
# network. Production deploys leave this as the default.
ROWBOAT_BASE_URL=http://rowboat:3000

# Per-tenant Rowboat project identifier. In our deploys this is the same
# UUID as the businesses.id, but kept as a separate env to keep Rowboat's
# identifier model decoupled from Supabase's.
ROWBOAT_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Rowboat API key for this project (= ROWBOAT_GATEWAY_TOKEN in /opt/rowboat/.env).
ROWBOAT_GATEWAY_TOKEN=<rowboat-api-key>

# This worker only handles jobs for this tenant.
BUSINESS_ID=00000000-0000-0000-0000-000000000000

# Vercel callback for the rolling-summary trigger. After each
# successful job, the worker fires a fire-and-forget POST to
# ${WORKER_VERCEL_BASE_URL}/api/internal/dashboard-chat-summarize with
# bearer ${WORKER_VERCEL_BEARER}. Skipping these env vars is
# equivalent to "summary updates never re-run from this worker" —
# the next turn's callback re-evaluates the threshold so missed
# triggers self-heal.
WORKER_VERCEL_BASE_URL=https://newcoworker.com
WORKER_VERCEL_BEARER=<INTERNAL_CRON_SECRET>

# Rowboat agent entered on owner-dashboard turns. Must match an agent in
# this tenant's seeded workflow. deploy-client.sh seeds "OwnerCoworker"
# (Coworker's tools + owner_append_business_memory), which is the default.
# Set to "" to omit startAgent (Rowboat then uses the workflow default,
# "Coworker") — do this for tenants still on a seed that predates
# OwnerCoworker so we don't send an agent name Rowboat silently ignores.
# CHAT_WORKER_OWNER_START_AGENT=OwnerCoworker

# Owner-rule memory capture. On every owner turn the worker runs a small
# local-Ollama extraction over the owner's message; if it states a durable
# business rule, it POSTs to ${WORKER_VERCEL_BASE_URL}/api/voice/tools/
# owner-append-business-memory (bearer = ROWBOAT_GATEWAY_TOKEN) to persist it
# to memory_md + vault-sync, then appends an honest "saved" confirmation to
# the reply. Requires WORKER_VERCEL_BASE_URL to be set; set
# MEMORY_CAPTURE_ENABLED=false to turn it off entirely.
# MEMORY_CAPTURE_ENABLED=true
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# MEMORY_CAPTURE_MODEL=qwen3:4b-instruct
# MEMORY_CAPTURE_TIMEOUT_MS=30000

# Tunables (defaults are fine for production):
# WORKER_STALE_CLAIM_MS=300000
# WORKER_SWEEP_INTERVAL_MS=30000
# WORKER_ROWBOAT_TIMEOUT_MS=240000
# WORKER_MAX_ATTEMPTS=3
