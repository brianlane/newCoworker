# Local integration tuning
# Copy to repo root as `.env.integration.local`.

# Keep Docker named volumes between runs for faster iteration.
INTEGRATION_KEEP_VOLUMES=1

# Defaults selected from correctness runs:
# INTEGRATION_OLLAMA_MODEL_KVM2=llama3.2:3b
# INTEGRATION_OLLAMA_MODEL_KVM8=qwen3:4b-instruct

# Run only one stack if needed.
# INTEGRATION_SKIP_KVM8=1
# INTEGRATION_SKIP_KVM2=1

# Run multiple starter tags sequentially in correctness mode.
# INTEGRATION_CORRECTNESS_MODEL_SEQUENCE=llama3.2:3b,llama3.2:3b-instruct-q2_K

# Long timeout for Ollama /v1 and Rowboat /chat.
# INTEGRATION_OLLAMA_CHAT_TIMEOUT_SEC=3600

# Retry counts and log tail size on failure.
# INTEGRATION_OLLAMA_CHAT_ATTEMPTS=12
# INTEGRATION_FAILURE_LOG_TAIL=120
