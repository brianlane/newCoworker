# Shared Rowboat env for integration (starter). Mirrors deploy-client.sh keys; paths are container paths.
NODE_ENV=production
PORT=3000
MONGODB_CONNECTION_STRING=mongodb://mongo:27017/rowboat
REDIS_URL=redis://redis:6379
# Production matches: PROVIDER_API_KEY below takes precedence in every
# fallback chain that used to read OPENAI_API_KEY, and the OpenAI Agents
# SDK tracing exporter is disabled here too so integration logs aren't
# noisy with the [non-fatal] 401 from a placeholder key.
OPENAI_AGENTS_DISABLE_TRACING=1
USE_AUTH=false
AUTH0_BASE_URL=http://127.0.0.1:13000
AUTH0_SECRET=test_secret
AUTH0_ISSUER_BASE_URL=https://test.invalid
AUTH0_CLIENT_ID=test
AUTH0_CLIENT_SECRET=test
AGENTS_API_URL=http://127.0.0.1:9
AGENTS_API_KEY=test
COPILOT_API_URL=http://127.0.0.1:9
COPILOT_API_KEY=test
USE_RAG=false
QDRANT_URL=http://127.0.0.1:9
QDRANT_API_KEY=
ROWBOAT_GATEWAY_TOKEN=integration_test_token
# OpenAI SDK compatibility — Ollama exposes /v1/chat/completions under base .../v1 (not bare :11434).
PROVIDER_BASE_URL=http://ollama:11434/v1
PROVIDER_API_KEY=ollama
ROWBOAT_VAULT_PATH=/vault
ROWBOAT_MEMORY_PATH=/memory
