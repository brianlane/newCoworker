{
  "version": "1",
  "_comment": "OpenClaw agent template. Use OPENCLAW_GATEWAY_TOKEN for this agent’s gateway auth (separate from Rowboat’s ROWBOAT_GATEWAY_TOKEN). Also substitute SUPABASE_URL, NOTIFICATIONS_WEBHOOK_TOKEN, Telnyx keys (same names as vps/scripts/deploy-client.sh where shared). Override browser.endpoint if LIGHTPANDA_WSS_URL differs from the default below.",
  "gateway_token": "{{OPENCLAW_GATEWAY_TOKEN}}",
  "features": {
    "chatCompletions": true,
    "losslessClaw": true,
    "browserSkills": true
  },
  "models": {
    "fast": "llama3.2:3b",
    "balanced": "llama3.2:3b",
    "deep": "llama4:9b"
  },
  "llm_router": "http://127.0.0.1:11434/v1",
  "soul_path": "/etc/openclaw/soul.md",
  "identity_path": "/etc/openclaw/identity.md",
  "memory": {
    "provider": "lossless_claw",
    "path": "/var/openclaw/memory",
    "max_tokens": 8192
  },
  "browser": {
    "provider": "lightpanda",
    "endpoint": "wss://cdn.lightpanda.io/ws"
  },
  "notification_webhook": "{{SUPABASE_URL}}/functions/v1/notifications",
  "notification_webhook_token": "{{NOTIFICATIONS_WEBHOOK_TOKEN}}",
  "compliance": {
    "fha_guardrails": true,
    "forbidden_topics": [
      "race",
      "religion",
      "national_origin",
      "familial_status",
      "disability",
      "sex",
      "color"
    ]
  },
  "skills": [
    {
      "id": "browser_search",
      "enabled": true,
      "description": "Headless browser automation via Lightpanda Cloud"
    },
    {
      "id": "lossless_memory",
      "enabled": true,
      "description": "Permanent DAG memory via Lossless Claw"
    },
    {
      "id": "crm_update",
      "enabled": true,
      "description": "Writes structured data back to webhook"
    },
    {
      "id": "appointment_book",
      "enabled": true,
      "description": "Calendar scheduling via webhook"
    }
  ],
  "telnyx": {
    "api_key": "{{TELNYX_API_KEY}}",
    "messaging_profile_id": "{{TELNYX_MESSAGING_PROFILE_ID}}",
    "sms_from_e164": "{{TELNYX_SMS_FROM_E164}}"
  }
}
